# --- WhatsApp (Meta Cloud API) ---
# From Meta for Developers -> your app -> WhatsApp -> API Setup
WHATSAPP_APP_SECRET=              # App Secret (for HMAC webhook signature verification)
WHATSAPP_ACCESS_TOKEN=            # Permanent or 24h access token (Bearer for Graph API)
WHATSAPP_PHONE_NUMBER_ID=         # Numeric ID (not the phone number itself)
WHATSAPP_VERIFY_TOKEN=            # Any string you choose; paste same value into Meta webhook config
WHATSAPP_ALLOWED_NUMBERS=         # Comma-separated E.164 numbers allowed to trigger bot, e.g. +61400111222,+61400999888
